# Do not put real keys in this file.
# Copy to .env.local for local development, or configure the same names in Vercel.

# LLMod.ai
LLMOD_API_KEY=
LLMOD_BASE_URL=
LLMOD_TEXT_MODEL=MB5R2CF-azure/gpt-5.4-mini
LLMOD_EMBEDDING_MODEL=MB5R2CF-azure/text-embedding-3-small

# Production uses live Agent and Supervisor decisions.
# For no-token local checks only, set LLM_MODE=mock.
LLM_MODE=live
LLM_LIVE_MODULES=agent,supervisor
LLM_MAX_TOKENS=450

# Pinecone review RAG
PINECONE_API_KEY=
PINECONE_REVIEW_INDEX=airbnb-reviews
PINECONE_REVIEW_NAMESPACE=airbnb-reviews
PINECONE_INDEX=airbnb-reviews
PINECONE_NAMESPACE=airbnb-reviews
REQUIRE_PINECONE_RAG=true

# Supabase primary runtime database
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
REQUIRE_SUPABASE_RUNTIME=true

# Optional, created by Vercel CLI when linked locally.
VERCEL_OIDC_TOKEN=
