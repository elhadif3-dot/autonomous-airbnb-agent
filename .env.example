# Do not put real keys in this file.
# Copy to .env.local for local development.

LLMOD_API_KEY=
LLMOD_BASE_URL=
LLMOD_TEXT_MODEL=MB5R2CF-azure/gpt-5.4-mini
LLMOD_EMBEDDING_MODEL=MB5R2CF-azure/text-embedding-3-small

# Keep this as mock unless the project owner explicitly approves token usage.
LLM_MODE=mock
LLM_LIVE_MODULES=agent,supervisor
LLM_MAX_TOKENS=450
# Leave unset for gpt-5-family LLMod deployments unless your model supports it.
LLM_TEMPERATURE=
# Optional. Leave unset if the LLMod endpoint rejects OpenAI JSON mode.
LLM_RESPONSE_FORMAT=

PINECONE_API_KEY=
PINECONE_INDEX=airbnb-reviews
PINECONE_REVIEW_INDEX=airbnb-reviews
PINECONE_NAMESPACE=airbnb-reviews
PINECONE_REVIEW_NAMESPACE=airbnb-reviews
REQUIRE_PINECONE_RAG=false
DISABLE_PINECONE_RAG=false
PINECONE_DIMENSION=1536
PINECONE_METRIC=cosine
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
REQUIRE_SUPABASE_RUNTIME=false

TEAM_STUDENT_1_NAME=Shoval Zvieli
TEAM_STUDENT_1_EMAIL=shovalzvieli@campus.technion.ac.il
TEAM_STUDENT_2_NAME=Daniel Elhadif-Kaminer
TEAM_STUDENT_2_EMAIL=edaniel@campus.technion.ac.il
TEAM_STUDENT_3_NAME=Opal Zvieli
TEAM_STUDENT_3_EMAIL=opalzvieli@campus.technion.ac.il
